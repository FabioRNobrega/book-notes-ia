@using WebApp.Services
@{
    ViewData["Title"] = "Home";
    var photo = ViewData["BackgroundPhoto"] as UnsplashPhoto;
}

<div class="fixed inset-0 -z-10 bg-cover bg-center bg-no-repeat"
     style="@(photo != null ? $"background-image: url('{photo.Url}');" : "background: #0f0f1a;")">
    <div class="absolute inset-0 bg-black/60"></div>
</div>

<div class="flex flex-col flex-1 min-h-0">
    <div id="chat-container" class="flex-1 min-h-0 flex flex-col overflow-hidden px-[30px] pt-3 pb-0">
        <div class="flex-1 min-h-0 overflow-y-auto"
            hx-get="@Url.Action("Chat", "Chat")"
            hx-trigger="load"
            hx-swap="innerHTML">
            <div class="mx-auto border border-white/10 bg-black/30 p-6 text-lg text-white/70 backdrop-blur-sm"
                style="max-width: var(--paper-style-width); border-radius: var(--book-radius);">
                Loading your assistant...
            </div>
        </div>
    </div>

    <div class="sticky bottom-0 z-30 px-4 pb-3 pt-0">
        <div class="mx-auto border border-white/10 p-3 shadow-2xl backdrop-blur-md"
             style="max-width: var(--book-dock-width); background-color: var(--background-transparency-default); border-radius: var(--book-radius);">
            <div id="chat-composer">
                <form id="chat-form"
                      class="relative flex items-center gap-3 border p-3 shadow-xl transition-colors"
                      style="background-color: var(--background-transparency-default); border-color: #3d3d3d; border-radius: var(--book-radius);"
                      hx-post="/chat/send"
                      hx-swap="none"
                      onfocusin="this.style.borderColor='var(--sl-color-primary-300)'"
                      onfocusout="this.style.borderColor='#3d3d3d'"
                    _="
                        on submit
                            set userMsg to #message.value
                            if userMsg is ''
                                halt the event
                            end

                            make a <div/> called wrapper
                            make a <div/> called thinker

                            set wrapper's innerHTML to `<div class='bg-stone-800/90 text-white/95 px-4 py-3 break-words' style='border-radius: var(--book-radius);'><p>${userMsg}</p></div>`
                            set thinker.id to 'agent-response'
                            set thinker's innerHTML to `<div class='flex items-center gap-3 text-white/95 px-4 py-3 break-words' style='border-radius: var(--book-radius);background-color: var(--background-transparency-default)'><sl-spinner></sl-spinner><span>Let me think on that...</span><span id='thinker-counter' class='text-white/60 text-lg font-semibold'>0s</span></div>`

                            add .flex to wrapper
                            add .flex-col to wrapper
                            add .items-end to wrapper
                            add .ml-auto to wrapper
                            add .w-full to wrapper

                            add .flex to thinker
                            add .flex-col to thinker
                            add .items-start to thinker
                            add .w-full to thinker

                            put wrapper at the end of #chat
                            set #message.value to ''
                            put thinker at the end of #chat

                            js
                                let elapsed = 0;
                                const timer = setInterval(function() {
                                    const el = document.getElementById('thinker-counter');
                                    if (!el) { clearInterval(timer); return; }
                                    elapsed++;
                                    el.innerText = elapsed + 's';
                                }, 1000);

                                const thinker = document.getElementById('agent-response');
                                if (thinker) {
                                    thinker.scrollIntoView({ behavior: 'smooth', block: 'start' });
                                }
                            end
                        end
                    ">

                    <input type="file" id="file-attach" class="hidden"
                           accept=".txt" data-chat-file-input="true" />

                    <button type="button" aria-label="Attach file"
                            onclick="document.getElementById('file-attach').click()"
                            class="flex size-10 shrink-0 items-center justify-center bg-transparent text-gray-400 transition-all hover:bg-[#3d3d3d] hover:text-white active:scale-95"
                            style="border-radius: var(--book-radius);">
                        <sl-icon name="paperclip" style="font-size:1.25rem;"></sl-icon>
                    </button>

                    <input
                        id="message"
                        name="message"
                        type="text"
                        placeholder="How can I help you today?"
                        autocomplete="off"
                        class="flex-1 bg-transparent px-2 py-2 outline-none placeholder-gray-500"
                        style="font-family:'Crimson Text',Georgia,serif; font-size:16px; color:white;"
                        onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();this.closest('form').requestSubmit();}"
                    />

                    <sl-tooltip content="Clear chat history" placement="top">
                        <button type="button" aria-label="Clear history"
                                hx-post="/chat/reset"
                                hx-target="#alert"
                                hx-swap="beforeend"
                                _="on click set #chat.innerHTML to ''"
                                class="flex size-10 shrink-0 items-center justify-center bg-transparent text-gray-400 transition-all hover:bg-[#3d3d3d] hover:text-white active:scale-95"
                                style="border-radius: var(--book-radius);">
                            <sl-icon name="arrow-counterclockwise" style="font-size:1.1rem;"></sl-icon>
                        </button>
                    </sl-tooltip>

                    <button type="submit" aria-label="Send message"
                            class="flex size-10 shrink-0 items-center justify-center bg-transparent text-gray-400 transition-all hover:bg-[#3d3d3d] hover:text-white active:scale-95"
                            style="border-radius: var(--book-radius);">
                        <sl-icon name="send" style="font-size:1.1rem;"></sl-icon>
                    </button>
                </form>
            </div>

            <div class="mt-3 flex w-full justify-center overflow-x-auto pb-1">
                <div class="flex flex-nowrap justify-center gap-2">
                <sl-button
                    id="mode-ai"
                    data-chat-mode-button="ai"
                    hx-get="@Url.Action("Chat", "Chat")"
                    hx-target="#chat-container"
                    hx-swap="innerHTML"
                    onclick="window.BookNotesChat?.setMode('ai')"
                    variant="primary"
                    outline
                    class="shrink-0"
                >
                    <sl-icon slot="prefix" name="chat-left-text"></sl-icon>
                    Talk with Our AI
                </sl-button>
                <sl-button
                    id="mode-upload"
                    data-chat-mode-button="upload"
                    hx-get="@Url.Action("Upload", "Notes")"
                    hx-target="#chat-container"
                    hx-swap="innerHTML"
                    onclick="window.BookNotesChat?.setMode('upload')"
                    variant="default"
                    outline
                    class="shrink-0">
                    <sl-icon slot="prefix" name="journal-arrow-down"></sl-icon>
                    Upload Notes
                </sl-button>
                <sl-button
                    id="mode-notes"
                    data-chat-mode-button="notes"
                    hx-get="@Url.Action("Library", "Notes")"
                    hx-target="#chat-container"
                    hx-swap="innerHTML"
                    onclick="window.BookNotesChat?.setMode('notes')"
                    variant="default"
                    outline
                    class="shrink-0">
                    <sl-icon slot="prefix" name="eye"></sl-icon>
                    See Your Notes
                </sl-button>
                <sl-button
                    id="mode-profile"
                    data-chat-mode-button="profile"
                    hx-get="@Url.Action("MyProfile", "UserProfile")"
                    hx-target="#chat-container"
                    hx-swap="innerHTML"
                    onclick="window.BookNotesChat?.setMode('profile')"
                    variant="default"
                    outline
                    class="shrink-0"
                >
                    <sl-icon slot="prefix" name="person-circle"></sl-icon>
                    My Profile
                </sl-button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (photo != null)
{
    <div class="fixed bottom-2 right-3 z-40 text-xs text-white/30 hover:text-white/60 transition-colors">
        Photo by
        <a href="@photo.PhotographerProfileUrl?utm_source=book_notes_ia&utm_medium=referral"
           target="_blank" rel="noopener" class="underline">@photo.PhotographerName</a>
        on
        <a href="https://unsplash.com?utm_source=book_notes_ia&utm_medium=referral"
           target="_blank" rel="noopener" class="underline">Unsplash</a>
    </div>
}

@section Scripts {
    <script src="~/js/site.js" asp-append-version="true"></script>
}
