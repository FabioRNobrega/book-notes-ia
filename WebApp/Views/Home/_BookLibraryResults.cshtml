@model BookLibraryResultsViewModel

@if (Model.IsLibrarianNotFound)
{
    <div class="p-6">
        <div class="border border-dashed border-white/15 px-5 py-8 text-center text-white/50"
             style="border-radius: var(--book-radius); background-color: rgba(255,255,255,0.04);">
            Hmm, even our librarian couldn't track this one down. Maybe you haven't read that book yet, or maybe a typo slipped in? Make sure you've uploaded your notes before giving it another try!
        </div>
    </div>
}
else if (Model.Books.Count == 0)
{
    <div class="p-6">
        <div class="border border-dashed border-white/15 px-5 py-8 text-center text-white/50"
             style="border-radius: var(--book-radius); background-color: rgba(255,255,255,0.04);">
            No imported books yet. Upload your <code>My Clippings.txt</code> file to build your library.
        </div>
    </div>
}
else
{
    @if (!string.IsNullOrWhiteSpace(Model.HeaderMessage))
    {
        <p class="px-5 pt-4 text-sm text-white/60">@Model.HeaderMessage</p>
    }
    <div class="grid grid-cols-2 gap-4 p-4 md:grid-cols-3 md:p-5 xl:grid-cols-5">
        @foreach (var book in Model.Books)
        {
            <button type="button"
                    hx-get="@Url.Action("Book", "Notes", new { id = book.Id })"
                    hx-target="#chat-container"
                    hx-swap="innerHTML"
                    class="group flex aspect-[3/4] w-full items-center justify-center overflow-hidden border text-center text-sm text-white/65 shadow-sm transition hover:-translate-y-0.5 hover:border-white/30"
                    style="border-radius: var(--book-radius); background-color: rgba(45, 45, 45, 0.92); border-color: rgba(255,255,255,0.12);"
                    title="@book.Title by @book.Author">
                @if (!string.IsNullOrWhiteSpace(book.CoverUrl))
                {
                    <img src="@book.CoverUrl" alt="@book.Title cover" class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.02]" />
                }
                else
                {
                    <span class="px-4 font-title text-lg leading-tight text-white/90">@book.Title</span>
                }
            </button>
        }
    </div>
}
