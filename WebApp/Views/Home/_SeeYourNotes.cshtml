@model NotesLibraryViewModel

<section class="border border-white/10 p-6 text-white/90 shadow-2xl backdrop-blur-md" style="background-color: var(--background-transparency-default); border-radius: var(--book-radius);">
    <div class="space-y-5">
        <div class="flex items-start justify-between gap-4">
            <div class="space-y-2">
                <p class="font-title text-2xl">See Your Notes</p>
                <p class="max-w-2xl text-lg text-white/70">
                    Your imported Kindle books appear here. Open any cover to see the saved highlights and notes.
                </p>
            </div>
            <sl-button variant="default"
                       outline
                       hx-get="@Url.Action("Upload", "Notes")"
                       hx-target="#chat-container"
                       hx-swap="innerHTML">
                <sl-icon slot="prefix" name="upload"></sl-icon>
                Upload More
            </sl-button>
        </div>

        @if (Model.Books.Count == 0)
        {
            <div class="border border-dashed border-white/15 px-5 py-8 text-center text-white/70"
                 style="border-radius: var(--book-radius);">
                No imported books yet. Upload your <code>My Clippings.txt</code> file to build your library.
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 gap-4 md:grid-cols-3 xl:grid-cols-5">
                @foreach (var book in Model.Books)
                {
                    <button type="button"
                            hx-get="@Url.Action("Book", "Notes", new { id = book.Id })"
                            hx-target="#chat-container"
                            hx-swap="innerHTML"
                            class="group flex aspect-[3/4] w-full items-center justify-center overflow-hidden border border-white/10 text-center text-sm text-white/60 transition hover:border-white/30 hover:bg-white/5"
                            style="border-radius: var(--book-radius); background-color: var(--background-transparency-default);"
                            title="@book.Title by @book.Author">
                        @if (!string.IsNullOrWhiteSpace(book.CoverUrl))
                        {
                            <img src="@book.CoverUrl" alt="@book.Title cover" class="h-full w-full object-cover transition duration-200 group-hover:scale-[1.02]" />
                        }
                        else
                        {
                            <span class="px-4 font-title text-lg leading-tight text-white/85">@book.Title</span>
                        }
                    </button>
                }
            </div>
        }
    </div>
</section>
