@model BookContextViewModel
@using Markdig

<div id="book-context-@Model.BookId">
    @if (string.IsNullOrWhiteSpace(Model.Context))
    {
        <div class="flex items-center gap-2 mt-4">
            <sl-button variant="default" outline size="small"
                       hx-post="/notes/book/@Model.BookId/context/generate"
                       hx-target="#book-context-@Model.BookId"
                       hx-swap="outerHTML"
                       hx-indicator="#context-spinner-@Model.BookId"
                       hx-disabled-elt="this">
                <sl-icon slot="prefix" name="stars"></sl-icon>
                Generate Context
            </sl-button>
            <sl-spinner id="context-spinner-@Model.BookId"
                        class="htmx-indicator"
                        style="font-size: 1rem; color: rgba(255,255,255,0.5);"></sl-spinner>
        </div>
    }
    else
    {
        <sl-details summary="Book Context" open class="mt-4">
            <div class="flex items-start gap-2">
                <div class="text-lg leading-relaxed flex-1 prose prose-invert prose-sm max-w-none" style="color: rgba(255,255,255,0.55);">@Html.Raw(Markdown.ToHtml(Model.Context!, new MarkdownPipelineBuilder().UseAdvancedExtensions().Build()))</div>
                <div class="flex shrink-0 items-center gap-1 pt-0.5">
                    <sl-tooltip content="Regenerate context with AI">
                        <sl-icon-button name="arrow-counterclockwise"
                                        label="Regenerate context"
                                        hx-post="/notes/book/@Model.BookId/context/generate"
                                        hx-target="#book-context-@Model.BookId"
                                        hx-swap="outerHTML"
                                        hx-indicator="#context-spinner-@Model.BookId"
                                        style="font-size: 1rem; color: rgba(255,255,255,0.35);"></sl-icon-button>
                    </sl-tooltip>
                    <sl-tooltip content="This context was generated by AI and may contain inaccuracies.">
                        <sl-icon name="question-circle"
                                 style="font-size: 0.85rem; color: rgba(255,255,255,0.25); cursor: help;"></sl-icon>
                    </sl-tooltip>
                    <sl-spinner id="context-spinner-@Model.BookId"
                                class="htmx-indicator"
                                style="font-size: 0.85rem; color: rgba(255,255,255,0.4);"></sl-spinner>
                </div>
            </div>
        </sl-details>
    }
</div>
