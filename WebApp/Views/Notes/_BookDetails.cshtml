@model BookDetailsViewModel

<section class="mx-auto flex h-full w-full flex-col overflow-hidden border border-white/10 text-white/90 shadow-2xl backdrop-blur-md"
         style="max-width: var(--book-panel-width); background-color: var(--sl-color-primary-800); border-radius: var(--book-radius) var(--book-radius) 0 0;">
    <div class="flex shrink-0 flex-wrap items-start justify-between gap-4 border-b p-6" style="border-bottom-color: var(--sl-color-primary-950);">
        <div class="flex gap-4">
            <div class="flex h-32 w-24 shrink-0 items-center justify-center overflow-hidden border border-white/10 text-center text-xs text-white/60"
                 style="border-radius: var(--book-radius); background: rgba(255,255,255,0.06);">
                @if (!string.IsNullOrWhiteSpace(Model.CoverUrl))
                {
                    <img src="@Model.CoverUrl" alt="@Model.Title cover" class="h-full w-full object-cover" />
                }
                else
                {
                    <span class="px-2 font-title">@Model.Title</span>
                }
            </div>
            <div class="space-y-2">
                <p class="font-title text-3xl leading-tight">@Model.Title</p>
                <p class="text-lg text-white/70">@Model.Author</p>
                <p class="text-base text-white/60">@Model.Notes.Count imported entries</p>
            </div>
        </div>

        <sl-button variant="default"
                   outline
                   style="border-color: var(--sl-color-primary-950); color: var(--sl-color-primary-50);"
                   hx-get="@Url.Action("Library", "Notes")"
                   hx-target="#chat-container"
                   hx-swap="innerHTML">
            <sl-icon slot="prefix" name="arrow-left"></sl-icon>
            Back to Library
        </sl-button>
    </div>

    <div class="flex-1 overflow-y-auto p-6"
         style="background: var(--book-paper-surface); color: var(--book-paper-ink);">
        <div class="space-y-3">
            @foreach (var note in Model.Notes)
            {
                <article class="border p-4 shadow-sm"
                         style="border-radius: var(--book-radius); border-color: var(--book-paper-rule); background-color: rgba(255,255,255,0.24);">
                    <div class="mb-3 flex flex-wrap items-center gap-2 text-sm" style="color: var(--book-paper-muted);">
                        <span class="font-title" style="color: var(--book-paper-ink);">@note.EntryType</span>
                        <span>•</span>
                        <span>@note.LocationText</span>
                        <span>•</span>
                        <span>@note.ClippedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <p class="whitespace-pre-wrap text-base leading-relaxed" style="color: var(--book-paper-ink);">@note.Content</p>
                </article>
            }
        </div>
    </div>
</section>
