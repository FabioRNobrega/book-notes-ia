@model IReadOnlyList<WebApp.Controllers.ChatEntry>
@using WebApp.Controllers

<div id="chat" class="flex flex-col gap-3 pb-10 overflow-y-auto">

    @if (Model == null || Model.Count == 0)
    {
        <div class="flex flex-col max-w-[75%]">
            <div class="text-white/90 px-4 py-3 text-lg break-words" style="background-color: var(--background-transparency-default); border-radius: var(--book-radius);">
                <p>Welcome to the Literary Chat. How may I assist you today?</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var entry in Model)
        {
            if (entry.Role == "user")
            {
                <div class="flex flex-col items-end ml-auto w-full">
                    <div class="bg-stone-800/90 text-white/95 px-4 py-3 break-words" style="border-radius: var(--book-radius);">
                        <p>@entry.Content</p>
                    </div>
                </div>
            }
            else
            {
                <div class="flex flex-col max-w-[75%]">
                    <div class="text-white/90 px-4 py-3 text-lg break-words" style="background-color: var(--background-transparency-default); border-radius: var(--book-radius);">
                        <div class="prose prose-invert max-w-none prose-sm">
                            @Html.Raw(entry.Content)
                        </div>
                        <div class="flex items-center mt-3 pt-1.5 border-t border-white/10">
                            @if (entry.MessageId.HasValue)
                            {
                                <div class="tts-widget flex items-center gap-1.5" data-audio-message-id="@entry.MessageId">
                                    <sl-tooltip class="tts-tooltip" content="Listen to this response">
                                        <sl-icon-button class="tts-play-btn text-white/40"
                                                        name="play-circle"
                                                        label="Listen to this response"
                                                        style="font-size:18px; --sl-color-primary-600:rgba(255,255,255,0.85); --sl-color-primary-700:rgba(255,255,255,1);">
                                        </sl-icon-button>
                                    </sl-tooltip>
                                    <span class="tts-loading" style="display:none; align-items:center; gap:5px; color:rgba(255,255,255,0.45); font-size:11px; white-space:nowrap;">
                                        <sl-spinner style="font-size:12px; --track-width:1.5px;"></sl-spinner>
                                        Generating audio...
                                    </span>
                                    <span class="tts-error" style="display:none; align-items:center; gap:4px; color:rgba(248,113,113,0.8); font-size:11px; white-space:nowrap;">
                                        <sl-icon name="exclamation-circle" style="font-size:12px;"></sl-icon>
                                        Audio unavailable
                                    </span>
                                </div>
                            }
                            @if (entry.ResponseTimeMs is not null)
                            {
                                <span class="ml-auto text-xs text-white/45 shrink-0">
                                    He thought for @WebApp.Controllers.ChatController.FormatResponseTime(entry.ResponseTimeMs)
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }

</div>
