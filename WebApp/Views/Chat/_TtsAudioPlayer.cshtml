@model Guid

<div class="tts-widget flex items-center gap-1.5" data-audio-message-id="@Model">
    <sl-tooltip class="tts-tooltip" content="Listen to this response">
        <sl-icon-button class="tts-play-btn text-white/40"
                        name="play-circle"
                        label="Listen to this response"
                        style="font-size:18px; --sl-color-primary-600:rgba(255,255,255,0.85); --sl-color-primary-700:rgba(255,255,255,1);">
        </sl-icon-button>
    </sl-tooltip>
    <span class="tts-loading" style="display:none; align-items:center; gap:5px; color:rgba(255,255,255,0.45); font-size:11px; white-space:nowrap;">
        <sl-spinner style="font-size:12px; --track-width:1.5px;"></sl-spinner>
        Generating audio...
    </span>
    <span class="tts-error" style="display:none; align-items:center; gap:4px; color:rgba(248,113,113,0.8); font-size:11px; white-space:nowrap;">
        <sl-icon name="exclamation-circle" style="font-size:12px;"></sl-icon>
        Audio unavailable
    </span>
    <div class="tts-progress">
        <span class="tts-seek-wrap">
            <input type="range" class="tts-seek" min="0" max="1" step="any" value="0" disabled aria-label="Seek audio position" />
        </span>
        <span class="tts-time">0:00 / 0:00</span>
    </div>
    <sl-tooltip class="tts-download-tooltip" content="Download audio">
        <sl-icon-button class="tts-download-btn text-white/40"
                        name="download"
                        label="Download audio"
                        style="font-size:16px; --sl-color-primary-600:rgba(255,255,255,0.85); --sl-color-primary-700:rgba(255,255,255,1);">
        </sl-icon-button>
    </sl-tooltip>
</div>
